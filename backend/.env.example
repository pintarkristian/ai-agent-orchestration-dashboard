# FastAPI
APP_NAME="AI Agent Orchestration Dashboard API"
ENVIRONMENT="local"
API_HOST="0.0.0.0"
API_PORT="8000"

# OpenRouter
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_DEFAULT_MODEL="openai/gpt-4o-mini"

# Database
DATABASE_URL="sqlite+aiosqlite:///./orchestration.db"

# CORS
# JSON array format is used by pydantic-settings.
CORS_ORIGINS='["http://localhost:5173"]'
